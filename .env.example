# =============================================================================
# GynOrg - Abwesenheitsplanungstool Environment Configuration
# =============================================================================

# AI API Keys (Required for AI features)
OPENROUTER_API_KEY="your_openrouter_api_key_here"     # Required: Format: sk-or-v1-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Required: Format: pplx-...

# Additional AI Provider Keys (Optional)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Optional: Format: sk-ant-api03-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional: Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional: For Google Gemini models
MISTRAL_API_KEY="your_mistral_key_here"               # Optional: For Mistral AI models
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional: For xAI AI models
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional: For Azure OpenAI models
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub features

# =============================================================================
# Backend Configuration (FastAPI)
# =============================================================================

# Database
DATABASE_URL="sqlite:///./data/gynorg.db"             # SQLite database path
DATABASE_ECHO=false                                   # Set to true for SQL query logging

# Security
JWT_SECRET_KEY="your-super-secret-jwt-key-here"       # Required: Generate with: openssl rand -hex 32
JWT_ALGORITHM="HS256"                                 # JWT algorithm
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30                   # Token expiration time

# Authentication (Single User)
ADMIN_USERNAME="MGanser"                              # Hardcoded admin username
ADMIN_PASSWORD_HASH="$2b$12$your_bcrypt_hash_here"   # Bcrypt hash of admin password

# API Configuration
API_V1_STR="/api/v1"                                  # API version prefix
PROJECT_NAME="GynOrg"                                 # Project name
PROJECT_VERSION="1.0.0"                              # Project version
DEBUG=false                                           # Set to true for development

# CORS Settings
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:5173" # Allowed origins

# =============================================================================
# Frontend Configuration (React)
# =============================================================================

# API Base URL
VITE_API_BASE_URL="http://localhost:8000"            # Backend API URL
VITE_API_VERSION="/api/v1"                           # API version

# Application Settings
VITE_APP_NAME="GynOrg"                               # Application name
VITE_APP_VERSION="1.0.0"                            # Application version
VITE_ENVIRONMENT="development"                       # Environment (development/production)

# =============================================================================
# Development & Testing
# =============================================================================

# Logging
LOG_LEVEL="INFO"                                     # Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Testing
TEST_DATABASE_URL="sqlite:///./data/test_gynorg.db"  # Test database path
PYTEST_TIMEOUT=30                                    # Test timeout in seconds

# =============================================================================
# Docker & Deployment
# =============================================================================

# Container Settings
CONTAINER_PORT=8000                                  # Container port
CONTAINER_HOST="0.0.0.0"                           # Container host

# Health Check
HEALTH_CHECK_INTERVAL=30                            # Health check interval in seconds

# =============================================================================
# Holiday Management
# =============================================================================

# Year Range Configuration
HOLIDAY_YEARS_PAST=2                                # Years to load in the past (default: 2)
HOLIDAY_YEARS_FUTURE=3                              # Years to load in the future (default: 3)

# Automatic Import Settings
HOLIDAY_AUTO_IMPORT_ON_STARTUP=true                 # Auto-import holidays on app startup (default: true)

# Scheduler Configuration
HOLIDAY_SCHEDULER_ENABLED=true                      # Enable monthly scheduler (default: true)
HOLIDAY_SCHEDULER_CRON="0 2 1 * *"                 # Cron expression (default: 1st day, 2:00 AM)

# Cleanup Settings (Optional)
HOLIDAY_CLEANUP_OLD_YEARS=false                     # Auto-delete old years (default: false)
HOLIDAY_CLEANUP_YEARS_THRESHOLD=5                   # Delete years older than X years (default: 5)
